@model List<CuoiKy_CCMTPTPM.Models.FavoriteItem>
@{
    ViewData["Title"] = "Trang yêu thích - Minh Thành";
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6 text-gray-800">Màn hình yêu thích - Minh Thành</h1>

    <div class="bg-white rounded-lg shadow-xl overflow-hidden border border-gray-200">
        <div class="bg-[#1e3a8a] text-center py-4">
            <h2 class="text-[#fbbf24] text-xl font-bold uppercase tracking-widest">Trang yêu thích</h2>
        </div>
        
        <div class="divide-y divide-gray-100" id="favorites-list">
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="flex flex-wrap md:flex-nowrap items-center p-6 bg-white hover:bg-gray-50 transition-colors fav-item" data-id="@item.ProductId">
                        <div class="flex items-center space-x-6 flex-grow">
                            <div class="w-8 flex items-center justify-center">
                                <i class="fa-solid fa-heart text-red-500 text-xl"></i>
                            </div>
                            <div class="w-24 h-24 bg-gray-50 rounded-lg p-2 flex items-center justify-center shadow-sm">
                                <img src="@item.ImageUrl" alt="@item.Name" class="max-h-full max-w-full object-contain">
                            </div>
                            <div>
                                <h3 class="font-bold text-lg text-gray-800">@item.Name</h3>
                                <p class="text-gray-500 text-sm">@item.Description</p>
                            </div>
                        </div>

                        <div class="flex items-center space-x-8 mt-4 md:mt-0">
                            <div class="text-lg font-semibold text-gray-700">@item.Price.ToString("N0")đ</div>
                            
                            <div class="flex items-center space-x-3 bg-gray-100 rounded-lg px-3 py-1 border border-gray-200">
                                <button class="w-6 h-6 flex items-center justify-center text-gray-500 hover:text-black transition-colors btn-update-fav" data-delta="-1">
                                    <i class="fa-solid fa-minus text-[10px]"></i>
                                </button>
                                <span class="w-8 text-center font-bold text-gray-800 fav-quantity">@item.Quantity</span>
                                <button class="w-6 h-6 flex items-center justify-center text-gray-500 hover:text-black transition-colors btn-update-fav" data-delta="1">
                                    <i class="fa-solid fa-plus text-[10px]"></i>
                                </button>
                            </div>

                            <div class="text-xl font-bold text-orange-600 w-32 text-right fav-total">@item.Total.ToString("N0")đ</div>

                            <button class="text-red-500 hover:text-red-600 transition-colors transform hover:scale-110 p-2 btn-remove-fav">
                                <i class="fa-solid fa-xmark text-2xl"></i>
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="p-12 text-center text-gray-400 text-xl italic">Danh sách yêu thích của bạn đang trống.</div>
            }
        </div>
    </div>

    <div class="mt-8">
        <a asp-action="Index" class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-10 rounded-lg shadow-lg transition-all inline-flex items-center transform hover:-translate-y-1 active:scale-95">
            <i class="fa-solid fa-arrow-left mr-2"></i> Quay lại
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Cập nhật số lượng trong trang yêu thích
            $('.btn-update-fav').click(function () {
                var itemRow = $(this).closest('.fav-item');
                var id = itemRow.data('id');
                var delta = $(this).data('delta');

                $.post('/Home/UpdateFavoriteQuantity', { productId: id, delta: delta }, function (res) {
                    if (res.success) {
                        itemRow.find('.fav-quantity').text(res.quantity);
                        itemRow.find('.fav-total').text(res.total);
                    }
                });
            });

            // Xóa khỏi danh sách yêu thích
            $('.btn-remove-fav').click(function () {
                if (!confirm('Xóa sản phẩm này khỏi danh sách yêu thích?')) return;

                var item = $(this).closest('.fav-item');
                var id = item.data('id');

                $.post('/Home/RemoveFromFavorites', { productId: id }, function (res) {
                    if (res.success) {
                        item.fadeOut(300, function() {
                            $(this).remove();
                            if ($('.fav-item').length === 0) {
                                $('#favorites-list').html('<div class="p-12 text-center text-gray-400 text-xl italic">Danh sách yêu thích của bạn đang trống.</div>');
                            }
                        });
                    }
                });
            });
        });
    </script>
}
