@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="bg-white min-h-screen pb-12">
    <div class="container mx-auto px-4 py-8">
        <!-- Page Title -->
        <h1 class="text-3xl font-bold text-gray-800 mb-8">Danh sách sản phẩm</h1>

        <!-- Filter Buttons (Gray pill container) -->
        <div class="flex flex-wrap gap-2 mb-10 bg-[#e5e7eb] p-1.5 rounded-full w-fit">
            <button class="px-10 py-2.5 rounded-full bg-white text-gray-800 font-bold shadow-sm transition-all text-sm">Tất cả</button>
            <button class="px-10 py-2.5 rounded-full text-gray-600 font-bold hover:text-gray-800 transition-all text-sm">Nữ</button>
            <button class="px-10 py-2.5 rounded-full text-gray-600 font-bold hover:text-gray-800 transition-all text-sm">Nam</button>
            <button class="px-10 py-2.5 rounded-full text-gray-600 font-bold hover:text-gray-800 transition-all text-sm">Unisex</button>
        </div>

        <!-- Product Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Product Card 1: Elegance Noir -->
            <div class="bg-[#e5e7eb] rounded-[2rem] overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col p-5">
                <a asp-controller="Home" asp-action="ImageViewer" class="block relative mb-5">
                    <div class="relative bg-white rounded-2xl overflow-hidden aspect-square flex items-center justify-center p-6 border-4 border-white">
                        <img src="https://images.unsplash.com/photo-1541643600914-78b084683601?auto=format&fit=crop&q=80&w=600" alt="Elegance Noir" class="max-h-full max-w-full object-contain">
                        <div class="absolute top-3 left-3 bg-red-500 text-white text-[11px] font-bold px-2.5 py-1 rounded-full shadow-sm">-22%</div>
                    </div>
                </a>
                <div class="flex flex-col flex-1 px-1">
                    <div class="mb-2">
                        <span class="bg-white px-4 py-1 rounded-full text-[11px] font-bold text-gray-700 uppercase shadow-sm">Nữ</span>
                    </div>
                    <div class="text-sm text-gray-500 font-medium mb-1">Maison Luxe</div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-3 leading-tight tracking-tight">Elegance Noir</h3>
                    
                    <div class="flex items-center gap-2 mb-6">
                        <div class="flex text-yellow-400 text-sm">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <span class="text-[11px] text-gray-400 font-bold">(252 đánh giá)</span>
                    </div>

                    <div class="mt-auto">
                        <div class="flex items-baseline gap-3 mb-5">
                            <span class="text-2xl font-bold text-gray-900">2.500.000 đ</span>
                            <span class="text-base text-gray-400 line-through decoration-1">3.200.000 đ</span>
                        </div>
                        <button class="w-full bg-[#65cc66] hover:bg-[#5bb85c] text-black font-bold py-4 rounded-xl flex items-center justify-center gap-3 transition-colors shadow-sm text-lg">
                            <i class="fa-solid fa-cart-shopping text-xl"></i>
                            Thêm giỏ hàng
                        </button>
                    </div>
                </div>
            </div>

            <!-- Product Card 2: Royal Collection -->
            <div class="bg-[#e5e7eb] rounded-[2rem] overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col p-5">
                <a asp-controller="Home" asp-action="ImageViewer" class="block relative mb-5">
                    <div class="relative bg-white rounded-2xl overflow-hidden aspect-square flex items-center justify-center p-6 border-4 border-white">
                        <img src="https://images.unsplash.com/photo-1592945403244-b3fbafd7f539?auto=format&fit=crop&q=80&w=600" alt="Royal Collection" class="max-h-full max-w-full object-contain">
                    </div>
                </a>
                <div class="flex flex-col flex-1 px-1">
                    <div class="mb-2">
                        <span class="bg-white px-4 py-1 rounded-full text-[11px] font-bold text-gray-700 uppercase shadow-sm">unisex</span>
                    </div>
                    <div class="text-sm text-gray-500 font-medium mb-1">Prestige</div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-3 leading-tight tracking-tight">Royal Collection</h3>
                    
                    <div class="flex items-center gap-2 mb-6">
                        <div class="flex text-yellow-400 text-sm">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <span class="text-[11px] text-gray-400 font-bold">(459 đánh giá)</span>
                    </div>

                    <div class="mt-auto">
                        <div class="flex items-baseline gap-3 mb-5">
                            <span class="text-2xl font-bold text-gray-900">3.800.000 đ</span>
                        </div>
                        <button class="w-full bg-[#65cc66] hover:bg-[#5bb85c] text-black font-bold py-4 rounded-xl flex items-center justify-center gap-3 transition-colors shadow-sm text-lg">
                            <i class="fa-solid fa-cart-shopping text-xl"></i>
                            Thêm giỏ hàng
                        </button>
                    </div>
                </div>
            </div>

            <!-- Product Card 3: Urban Legend -->
            <div class="bg-[#e5e7eb] rounded-[2rem] overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col p-5">
                <a asp-controller="Home" asp-action="ImageViewer" class="block relative mb-5">
                    <div class="relative bg-white rounded-2xl overflow-hidden aspect-square flex items-center justify-center p-6 border-4 border-white">
                        <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=600" alt="Urban Legend" class="max-h-full max-w-full object-contain">
                    </div>
                </a>
                <div class="flex flex-col flex-1 px-1">
                    <div class="mb-2">
                        <span class="bg-white px-4 py-1 rounded-full text-[11px] font-bold text-gray-700 uppercase shadow-sm">Nam</span>
                    </div>
                    <div class="text-sm text-gray-500 font-medium mb-1">Modern Scent</div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-3 leading-tight tracking-tight">Urban Legend</h3>
                    
                    <div class="flex items-center gap-2 mb-6">
                        <div class="flex text-yellow-400 text-sm">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <span class="text-[11px] text-gray-400 font-bold">(236 đánh giá)</span>
                    </div>

                    <div class="mt-auto">
                        <div class="flex items-baseline gap-3 mb-5">
                            <span class="text-2xl font-bold text-gray-900">1.800.000 đ</span>
                        </div>
                        <button class="w-full bg-[#65cc66] hover:bg-[#5bb85c] text-black font-bold py-4 rounded-xl flex items-center justify-center gap-3 transition-colors shadow-sm text-lg">
                            <i class="fa-solid fa-cart-shopping text-xl"></i>
                            Thêm giỏ hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>