@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container mx-auto px-4 py-8">
    <!-- Back Button -->
    <a asp-controller="Home" asp-action="Index" class="inline-flex items-center text-gray-600 hover:text-orange-500 mb-6 font-medium transition-colors">
        <i class="fa-solid fa-arrow-left mr-2"></i> Quay lại
    </a>

    <!-- Main Content Card -->
    <div class="bg-gray-200 rounded-lg p-6 md:p-10 flex flex-col md:flex-row gap-10">
        <!-- Left: Images -->
        <div class="w-full md:w-2/5 space-y-4">
            <div class="bg-white rounded-lg p-8 flex items-center justify-center aspect-square shadow-inner">
                <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=800" alt="Product Image" class="max-h-full max-w-full object-contain">
            </div>
            <div class="grid grid-cols-4 gap-3">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="bg-white rounded-md p-2 flex items-center justify-center aspect-square cursor-pointer border-2 @(i == 0 ? "border-orange-500" : "border-transparent hover:border-gray-300") transition-all">
                        <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=200" alt="Thumbnail" class="max-h-full max-w-full object-contain">
                    </div>
                }
            </div>
        </div>

        <!-- Right: Info -->
        <div class="w-full md:w-3/5 space-y-6">
            <h1 class="text-3xl font-bold text-gray-800">Jean Paul Gaultier Le Male Le Parfum</h1>
            
            <div class="space-y-2">
                <p class="text-gray-600">Tình trạng: <span class="text-gray-800 font-semibold">Còn hàng</span></p>
                <p class="text-2xl font-bold text-gray-900">Giá: 325.000đ</p>
            </div>

            <p class="text-gray-700 leading-relaxed text-sm">
                Nước hoa Jean Paul Gaultier Le Male Le Parfum sở hữu những nốt hương đầy nam tính và bùng nổ. Le Male Le Parfum sẽ đem đến một vẻ ngoài đầy thu hút, quyến rũ dành cho các chàng.
            </p>

            <div class="space-y-4 pt-4 border-t border-gray-300">
                <div class="flex items-center">
                    <span class="w-24 text-gray-600">Giới tính:</span>
                    <span class="font-bold">Nam</span>
                </div>
                <div class="flex items-center">
                    <span class="w-24 text-gray-600">Xuất sứ:</span>
                    <span class="font-bold">Pháp</span>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                    <span class="w-24 text-gray-600">Dung tích:</span>
                    <button class="px-4 py-1.5 rounded border border-gray-400 font-bold bg-white hover:border-green-500 transition-colors">Chiết 10ml</button>
                    <button class="px-4 py-1.5 rounded border border-gray-300 text-gray-400 cursor-not-allowed">Chiết 20ml</button>
                    <button class="px-4 py-1.5 rounded border border-gray-300 text-gray-400 cursor-not-allowed">Chiết 30ml</button>
                    <button class="px-4 py-1.5 rounded border border-gray-300 text-gray-400 cursor-not-allowed">Fullbox 125ml</button>
                </div>
                <div class="flex items-center">
                    <span class="w-24 text-gray-600">Số lượng:</span>
                    <div class="flex items-center border border-gray-400 rounded bg-white">
                        <button class="px-3 py-1 hover:bg-gray-100">-</button>
                        <input type="text" value="1" class="w-12 text-center border-x border-gray-400 py-1 focus:outline-none">
                        <button class="px-3 py-1 hover:bg-gray-100">+</button>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 pt-6">
                <button class="flex-1 bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-lg transition-all shadow-lg hover:shadow-xl">
                    Mua ngay
                </button>
                <button class="flex-1 bg-transparent border-2 border-green-500 text-green-600 hover:bg-green-50 font-bold py-4 rounded-lg transition-all">
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </div>
</div>
