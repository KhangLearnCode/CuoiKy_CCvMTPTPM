@{
    ViewData["Title"] = "Image Viewer";
}

<div class="bg-white min-h-screen">
    <!-- Breadcrumbs -->
    <div class="container mx-auto px-4 py-4">
        <nav class="text-sm text-gray-400 font-medium">
            <a asp-controller="Home" asp-action="Index" class="hover:text-orange-500 transition-colors">Trang chủ</a>
            <span class="mx-2">>></span>
            <span class="text-gray-800">Jean Paul Gaultier Le Male Le Parfum</span>
        </nav>
    </div>

    <div class="container mx-auto px-4 py-8">
        <!-- Main Product Section -->
        <div class="bg-[#e5e7eb] rounded-[2.5rem] p-8 lg:p-12">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
                <!-- Left Column: Product Image -->
                <div class="lg:col-span-5">
                    <div class="bg-white rounded-3xl shadow-sm overflow-hidden p-10 aspect-square flex items-center justify-center border-[12px] border-white">
                        <img src="https://parfumerie.vn/uploads/products/jean-paul-gaultier-le-male-le-parfum-edp-intense.jpg" alt="Jean Paul Gaultier Le Male Le Parfum" class="max-h-full object-contain">
                    </div>
                </div>

                <!-- Right Column: Product Details -->
                <div class="lg:col-span-7 flex flex-col h-full">
                    <h1 class="text-4xl font-bold text-gray-900 mb-8 tracking-tight">Jean Paul Gaultier Le Male Le Parfum</h1>
                    
                    <div class="space-y-6 mb-10">
                        <p class="text-gray-500 font-bold text-lg">Tình trạng: <span class="text-gray-400 font-medium">Còn hàng</span></p>
                        <div class="text-3xl font-bold text-gray-900">Giá: <span class="border-b-4 border-black pb-1">325.000đ</span></div>
                        
                        <p class="text-gray-800 leading-relaxed text-lg max-w-2xl font-medium">
                            Nước hoa Jean Paul Gaultier Le Male Le Parfum sở hữu những nốt hương đầy nam tính và bùng nổ. Le Male Le Parfum sẽ đem đến một vẻ ngoài đầy thu hút, quyến rũ dành cho các chàng.
                        </p>
                    </div>

                    <div class="space-y-6 mb-12 flex-1">
                        <div class="flex items-center text-lg">
                            <span class="w-32 text-gray-600 font-bold">Giới tính:</span>
                            <span class="font-bold text-gray-900">Nam</span>
                        </div>
                        <div class="flex items-center text-lg">
                            <span class="w-32 text-gray-600 font-bold">Xuất sứ:</span>
                            <span class="font-bold text-gray-900">Pháp</span>
                        </div>
                        <div class="flex flex-wrap items-center gap-4 text-lg">
                            <span class="w-32 text-gray-600 font-bold">Dung tích:</span>
                            <div class="flex flex-wrap gap-3">
                                <button class="px-6 py-2 rounded-lg bg-black text-white font-bold text-sm shadow-md">Chiết 10ml</button>
                                <button class="px-6 py-2 rounded-lg bg-transparent border-2 border-gray-400 text-gray-400 font-bold text-sm cursor-not-allowed">Chiết 20ml</button>
                                <button class="px-6 py-2 rounded-lg bg-transparent border-2 border-gray-400 text-gray-400 font-bold text-sm cursor-not-allowed">Chiết 30ml</button>
                                <button class="px-6 py-2 rounded-lg bg-transparent border-2 border-gray-400 text-gray-400 font-bold text-sm cursor-not-allowed">Fullbox 125ml</button>
                            </div>
                        </div>
                        <div class="flex items-center text-lg">
                            <span class="w-32 text-gray-600 font-bold">Số lượng:</span>
                            <div class="flex items-center border-2 border-gray-400 rounded-lg bg-white overflow-hidden shadow-sm">
                                <button class="px-5 py-2 bg-gray-100 hover:bg-gray-200 border-r-2 border-gray-400 text-gray-700 font-black text-xl">-</button>
                                <input type="text" value="1" class="w-14 text-center py-2 text-lg font-bold focus:outline-none">
                                <button class="px-5 py-2 bg-gray-100 hover:bg-gray-200 border-l-2 border-gray-400 text-gray-700 font-black text-xl">+</button>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-6">
                        <button class="flex-1 bg-[#65cc66] hover:bg-[#5bb85c] text-black font-black py-5 rounded-2xl transition-all shadow-lg text-xl tracking-wide uppercase">
                            Mua ngay
                        </button>
                        <button class="flex-1 bg-[#65cc66] hover:bg-[#5bb85c] text-black font-black py-5 rounded-2xl transition-all shadow-lg text-xl tracking-wide uppercase">
                            Thêm vào giỏ
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>