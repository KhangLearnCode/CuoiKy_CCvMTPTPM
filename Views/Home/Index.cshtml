@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mx-auto px-4 py-6">
    <!-- Banner -->
    <div class="relative w-full h-[400px] rounded-lg overflow-hidden mb-8 group">
        <img src="https://images.unsplash.com/photo-1541643600914-78b084683601?auto=format&fit=crop&q=80&w=1600" alt="Perfume Banner" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-black/30 flex flex-col justify-center items-center text-center text-white px-4">
            <h2 class="text-4xl md:text-5xl font-bold mb-4">Đánh Thức Mọi Giác Quan</h2>
            <p class="text-xl mb-8 max-w-2xl">Bộ sưu tập nước hoa đẳng cấp dành riêng cho bạn</p>
            <button class="bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-10 rounded-full transition-all duration-300">Khám phá ngay</button>
        </div>
        <!-- Christmas Badge (Optional) -->
        <div class="absolute top-4 right-4 bg-red-600 text-white px-4 py-2 rounded-full font-bold animate-pulse">
            Christmas & Happy New Year
        </div>
    </div>

    <div class="flex flex-col md:flex-row gap-8">
        <!-- Sidebar -->
        <aside class="w-full md:w-1/4 bg-gray-200 p-6 rounded-lg self-start">
            <h3 class="text-xl font-bold mb-6 border-b border-gray-400 pb-2">Loại nước hoa</h3>
            <div class="space-y-4 mb-8">
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="radio" name="category" class="form-radio text-orange-500 w-5 h-5">
                    <span class="text-gray-700">Nam</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="radio" name="category" class="form-radio text-orange-500 w-5 h-5">
                    <span class="text-gray-700">Nữ</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="radio" name="category" class="form-radio text-orange-500 w-5 h-5">
                    <span class="text-gray-700">Unisex</span>
                </label>
            </div>

            <h3 class="text-xl font-bold mb-6 border-b border-gray-400 pb-2">Khoảng giá</h3>
            <div class="mb-8">
                <input type="range" min="0" max="10000000" step="100000" class="w-full h-2 bg-gray-400 rounded-lg appearance-none cursor-pointer accent-black">
                <div class="flex justify-between text-sm mt-2 font-medium">
                    <span>0đ</span>
                    <span>10.000.000đ</span>
                </div>
            </div>

            <h3 class="text-xl font-bold mb-6 border-b border-gray-400 pb-2">Thương hiệu</h3>
            <select class="w-full bg-white border border-gray-300 rounded-md py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-orange-500">
                <option>Chanel</option>
                <option>Dior</option>
                <option>Gucci</option>
                <option>Versace</option>
            </select>
        </aside>

        <!-- Main Content -->
        <div class="w-full md:w-3/4 space-y-12">
            <!-- Nước hoa nam section -->
            <section>
                <div class="flex items-center justify-between mb-6 bg-teal-500 text-white p-3 rounded-t-xl">
                    <h2 class="text-xl font-bold">Nước hoa nam</h2>
                    <a href="#" class="text-sm font-semibold flex items-center hover:underline">Tất cả <i class="fa-solid fa-arrow-right ml-2"></i></a>
                </div>
                <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
                    @for (int i = 0; i < 6; i++)
                    {
                        var prodId = 100 + i;
                        var prodName = "Nước hoa nam " + (i + 1);
                        var prodPrice = 3550000;
                        var prodImg = "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=400";
                        
                        <div class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow group product-card" 
                             data-id="@prodId" data-name="@prodName" data-desc="Nước hoa nam cao cấp" data-price="@prodPrice" data-img="@prodImg">
                            <div class="relative h-40 bg-gray-50 flex items-center justify-center p-4">
                                <a asp-controller="Home" asp-action="ProductDetail">
                                    <img src="@prodImg" alt="@prodName" class="max-h-full max-w-full object-contain">
                                </a>
                                <div class="absolute top-2 left-2 bg-red-500 text-white text-[10px] px-2 py-0.5 rounded-full">-15%</div>
                            </div>
                            <div class="p-3">
                                <h3 class="text-xs font-semibold text-gray-800 line-clamp-2 mb-2 group-hover:text-orange-500 transition-colors">@prodName</h3>
                                <div class="text-[10px] text-gray-500 mb-2">@prodPrice.ToString("N0")đ</div>
                                <div class="flex items-center justify-between">
                                    <button class="p-1.5 rounded-md hover:bg-gray-100 btn-add-cart" title="Thêm vào giỏ hàng">
                                        <i class="fa-solid fa-cart-shopping text-gray-600"></i>
                                    </button>
                                    <button class="p-1.5 rounded-md hover:bg-gray-100 btn-add-fav" title="Thêm vào yêu thích">
                                        <i class="fa-regular fa-heart text-gray-600"></i>
