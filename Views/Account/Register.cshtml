@model CuoiKy_CCMTPTPM.Models.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #2a2a2a; }
        .bg-custom-blue { background-color: #3b5c8d; }
        .bg-custom-light-blue { background-color: #9cbbf1; }
        .bg-custom-green { background-color: #2ecc71; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-2xl p-8 pt-10 pb-10 shadow-lg" style="width: 700px;">
        
        <div class="flex">
            <!-- Left side just spacing or we can align correctly -->
            <div class="w-1/3"></div>
            <div class="w-2/3 pl-4 pr-12">
                <div class="bg-custom-blue text-white text-center py-3 mb-8 w-full font-bold text-xl">
                    Đăng ký
                </div>
            </div>
        </div>

        <form asp-controller="Account" asp-action="Register" method="POST">
            <!-- Họ và tên -->
            <div class="flex mb-4 items-center">
                <div class="w-1/3 text-right pr-6">
                    <label asp-for="FullName" class="block text-gray-900 font-bold text-sm">Họ và tên:</label>
                </div>
                <div class="w-2/3 pr-12">
                    <input type="text" asp-for="FullName" class="w-full bg-custom-light-blue h-10 px-3 outline-none border-none">
                    <span asp-validation-for="FullName" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- Email -->
            <div class="flex mb-4 items-center">
                <div class="w-1/3 text-right pr-6">
                    <label asp-for="Email" class="block text-gray-900 font-bold text-sm">Email:</label>
                </div>
                <div class="w-2/3 pr-12">
                    <input type="email" asp-for="Email" class="w-full bg-custom-light-blue h-10 px-3 outline-none border-none">
                    <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- SĐT -->
            <div class="flex mb-4 items-center">
                <div class="w-1/3 text-right pr-6">
                    <label asp-for="PhoneNumber" class="block text-gray-900 font-bold text-sm">SĐT:</label>
                </div>
                <div class="w-2/3 pr-12">
                    <input type="text" asp-for="PhoneNumber" class="w-full bg-custom-light-blue h-10 px-3 outline-none border-none">
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- Mật khẩu -->
            <div class="flex mb-4 items-center">
                <div class="w-1/3 text-right pr-6">
                    <label asp-for="Password" class="block text-gray-900 font-bold text-sm">Mật khẩu:</label>
                </div>
                <div class="w-2/3 pr-12">
                    <input type="password" asp-for="Password" class="w-full bg-custom-light-blue h-10 px-3 outline-none border-none">
                    <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- Nhập lại mật khẩu -->
            <div class="flex mb-8 items-center">
                <div class="w-1/3 text-right pr-6">
                    <label asp-for="ConfirmPassword" class="block text-gray-900 font-bold text-sm">Nhập lại mật khẩu:</label>
                </div>
                <div class="w-2/3 pr-12">
                    <input type="password" asp-for="ConfirmPassword" class="w-full bg-custom-light-blue h-10 px-3 outline-none border-none">
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- Submit -->
            <div class="flex mt-6">
                <div class="w-1/3"></div>
                <div class="w-2/3 text-center pr-12">
                    <button type="submit" class="bg-custom-green text-black font-bold py-2 px-6 hover:bg-green-500 transition-colors">
                        Đăng ký
                    </button>
                    <div class="text-center mt-4">
                        <a asp-controller="Account" asp-action="Login" class="text-xs font-bold text-black hover:underline cursor-pointer">Bạn đã có tài khoản ? Đăng nhập ngay</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</body>
</html>
