@model CuoiKy_CCMTPTPM.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #2a2a2a; }
        .bg-custom-blue { background-color: #3b5c8d; }
        .bg-custom-light-blue { background-color: #9cbbf1; }
        .bg-custom-green { background-color: #2ecc71; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-md p-8 pt-10 pb-10 shadow-lg" style="width: 500px; height: auto;">
        
        <div class="bg-custom-blue text-white text-center py-3 mb-8 mx-auto w-4/5 font-bold text-xl">
            Đăng nhập
        </div>

        <form asp-controller="Account" asp-action="Login" method="POST" class="w-4/5 mx-auto">
            <div class="mb-5">
                <label asp-for="EmailOrPhone" class="block text-gray-900 font-bold mb-2 text-sm">Email/SĐT:</label>
                <input type="text" asp-for="EmailOrPhone" class="w-full bg-custom-light-blue h-10 px-3 outline-none border-none">
                <span asp-validation-for="EmailOrPhone" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Password" class="block text-gray-900 font-bold mb-2 text-sm">Mật khẩu:</label>
                <input type="password" asp-for="Password" class="w-full bg-custom-light-blue h-10 px-3 outline-none border-none">
                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-8 flex items-center">
                <input type="checkbox" asp-for="RememberMe" id="remember" class="mr-2 h-4 w-4 rounded-full border-gray-400">
                <label for="remember" class="text-xs font-bold text-gray-800">Ghi nhớ đăng nhập</label>
            </div>

            <div class="text-center">
                <button type="submit" class="bg-custom-green text-black font-bold py-2 px-6 hover:bg-green-500 transition-colors">
                    Đăng nhập
                </button>
            </div>

            <div class="text-center mt-6">
                <a asp-controller="Account" asp-action="Register" class="text-xs font-bold text-black hover:underline cursor-pointer">Chưa có tài khoản ? Đăng ký ngay</a>
            </div>
        </form>
    </div>
</body>
</html>
