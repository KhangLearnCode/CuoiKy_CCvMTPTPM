<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Console</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        .sidebar-link.active {
            color: #15803d; /* text-green-700 */
            background-color: #f9fafb; /* bg-gray-50 */
            border-left: 4px solid #16a34a; /* border-green-600 */
        }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white shadow-md flex flex-col justify-between z-20">
        <div>
            <div class="px-6 py-8">
                <a asp-controller="Admin" asp-action="Index">
                    <h1 class="text-2xl font-bold text-green-700">Admin</h1>
                    <p class="text-xs text-gray-500">Management Console</p>
                </a>
            </div>
            <nav class="mt-2">
                <a asp-controller="Admin" asp-action="Index" class="sidebar-link flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fa-solid fa-chart-line w-6 text-center"></i>
                    <span class="ml-3 font-medium">Dashboard</span>
                </a>
                <a asp-controller="Admin" asp-action="Products" class="sidebar-link flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")">
                    <i class="fa-solid fa-box w-6 text-center"></i>
                    <span class="ml-3 font-medium">Products</span>
                </a>
                <a asp-controller="Admin" asp-action="Orders" class="sidebar-link flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")">
                    <i class="fa-solid fa-truck-fast w-6 text-center"></i>
                    <span class="ml-3 font-medium">Orders</span>
                </a>
                <a asp-controller="Admin" asp-action="Customers" class="sidebar-link flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Customers" ? "active" : "")">
                    <i class="fa-solid fa-users w-6 text-center"></i>
                    <span class="ml-3 font-medium">Customers</span>
                </a>
                <a href="#" class="sidebar-link flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                    <i class="fa-solid fa-gear w-6 text-center"></i>
                    <span class="ml-3 font-medium">Settings</span>
                </a>
            </nav>
        </div>
        <div class="mb-8">
            <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                <i class="fa-regular fa-circle-question w-6 text-center"></i>
                <span class="ml-3 font-medium">Support</span>
            </a>
            <a asp-controller="Home" asp-action="Index" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                <i class="fa-solid fa-arrow-right-from-bracket w-6 text-center"></i>
                <span class="ml-3 font-medium">Exit Admin</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col overflow-hidden bg-gray-50">
        
        <!-- Top Nav -->
        <header class="bg-white px-8 py-4 flex items-center justify-between border-b z-10">
            <nav class="hidden md:flex space-x-8 text-sm font-medium text-gray-600">
                <a asp-controller="Home" asp-action="Index" class="hover:text-gray-900">Shop</a>
                <a asp-controller="Home" asp-action="ProductList" class="hover:text-gray-900">Collections</a>
                <a href="#" class="hover:text-gray-900">Heritage</a>
                <a href="#" class="hover:text-gray-900">Journal</a>
            </nav>
            <div class="flex items-center space-x-6">
                <div class="relative">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                    <input type="text" placeholder="Search catalog..." class="bg-gray-100 text-sm rounded-full py-2 pl-9 pr-4 focus:outline-none focus:ring-1 focus:ring-green-500 w-48">
                </div>
                <button class="text-gray-500 hover:text-gray-700 relative">
                    <i class="fa-regular fa-bell text-lg"></i>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <a asp-controller="Account" asp-action="Profile" class="text-gray-500 hover:text-gray-700">
                    <i class="fa-regular fa-user text-lg"></i>
                </a>
            </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-y-auto p-8">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>