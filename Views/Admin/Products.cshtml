@model CuoiKy_CCMTPTPM.Models.AdminProductViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin - Product Management";
}

<!-- Page Header -->
<div class="flex justify-between items-center mb-8">
    <div>
        <h2 class="text-2xl font-bold text-gray-900">Product Management</h2>
        <p class="text-sm text-gray-500 mt-1">Curate and manage your fragrance collection</p>
    </div>
    <button class="bg-[#2ecc71] hover:bg-green-500 text-white font-medium py-2 px-4 rounded text-sm transition-colors flex items-center shadow-sm">
        <i class="fa-solid fa-plus mr-2"></i> Add New Product
    </button>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    
    <!-- Total SKUs -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col justify-between">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Total SKUs</h3>
        <div class="flex items-end space-x-3">
            <span class="text-3xl font-bold text-gray-900">@Model.TotalSKUs.ToString("N0")</span>
            <span class="text-sm font-medium text-green-500 flex items-center mb-1">
                <i class="fa-solid fa-arrow-trend-up mr-1 text-xs"></i> 12
            </span>
        </div>
    </div>

    <!-- Out of Stock -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col justify-between">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Out of Stock</h3>
        <div class="flex items-center space-x-3">
            <span class="text-3xl font-bold text-gray-900">@Model.OutOfStock.ToString("D2")</span>
            <span class="text-xs font-bold text-red-500 uppercase flex items-center">
                <i class="fa-solid fa-triangle-exclamation mr-1"></i> Action needed
            </span>
        </div>
    </div>

    <!-- Best Seller -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col justify-between">
        <h3 class="text-xs font-bold text-green-500 uppercase tracking-wider mb-3">Best Seller</h3>
        <div class="flex items-center">
            <div class="w-12 h-12 bg-amber-800 rounded mr-4 flex-shrink-0"></div>
            <div>
                <p class="text-sm font-bold text-gray-900">@Model.BestSellerName</p>
                <p class="text-xs text-gray-500">@Model.BestSellerUnits units this month</p>
            </div>
        </div>
    </div>

</div>

<!-- Inventory List -->
<div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
        <h3 class="text-lg font-bold text-gray-900">Inventory List</h3>
        <div class="flex space-x-4">
            <button class="text-sm font-medium text-gray-600 hover:text-gray-900 flex items-center"><i class="fa-solid fa-filter mr-2 text-xs"></i> Filter</button>
            <button class="text-sm font-medium text-gray-600 hover:text-gray-900 flex items-center"><i class="fa-solid fa-download mr-2 text-xs"></i> Export</button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-600">
            <thead class="text-xs font-bold text-gray-400 uppercase bg-gray-50">
                <tr>
                    <th class="px-6 py-4 w-2/5">Product</th>
                    <th class="px-6 py-4 w-1/5">Category</th>
                    <th class="px-6 py-4 w-1/5">Price</th>
                    <th class="px-6 py-4 w-1/5">Stock Status</th>
                    <th class="px-6 py-4 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var item in Model.InventoryList)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center">
                                @{
                                    var bgColor = item.ImageType == "wooden" ? "bg-amber-100" : (item.ImageType == "floral" ? "bg-pink-100" : "bg-blue-100");
                                    var iconColor = item.ImageType == "wooden" ? "text-amber-600" : (item.ImageType == "floral" ? "text-pink-500" : "text-blue-500");
                                    var iconClass = item.ImageType == "wooden" ? "fa-bottle-droplet" : (item.ImageType == "floral" ? "fa-spray-can" : "fa-flask");
                                }
                                <div class="w-10 h-10 @bgColor rounded mr-4 flex-shrink-0 flex items-center justify-center">
                                    <i class="fa-solid @iconClass @iconColor"></i>
                                </div>
                                <div>
                                    <p class="font-bold text-gray-900">@item.Name</p>
                                    <p class="text-xs text-gray-400 mt-0.5">SKU: @item.SKU</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 font-medium @(item.Category == "WOODEN" ? "text-green-700" : (item.Category == "FLORAL" ? "text-pink-500" : "text-blue-500"))">@item.Category</td>
                        <td class="px-6 py-4 font-medium text-gray-900">$@item.Price.ToString("F2")</td>
                        <td class="px-6 py-4">
                            <span class="flex items-center @(item.StockStatus == "Low Stock" ? "text-red-500" : "text-gray-600") font-medium text-sm">
                                <span class="w-2 h-2 rounded-full @(item.StockStatus == "Low Stock" ? "bg-red-500" : "bg-green-500") mr-2"></span>
                                @item.StockStatus <span class="text-gray-400 ml-1">(@item.StockQuantity)</span>
                            </span>
                        </td>
                        <td class="px-6 py-4 text-center text-gray-400 hover:text-gray-700 cursor-pointer">
                            <i class="fa-solid fa-ellipsis"></i>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between bg-gray-50">
        <p class="text-sm text-gray-500">Showing 1-@Model.InventoryList.Count of @Model.TotalSKUs.ToString("N0") products</p>
        <div class="flex items-center space-x-1">
            <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-gray-600"><i class="fa-solid fa-chevron-left text-xs"></i></button>
            <button class="w-8 h-8 flex items-center justify-center bg-green-600 text-white font-medium rounded text-sm">1</button>
            <button class="w-8 h-8 flex items-center justify-center text-gray-600 hover:bg-gray-200 font-medium rounded text-sm">2</button>
            <button class="w-8 h-8 flex items-center justify-center text-gray-600 hover:bg-gray-200 font-medium rounded text-sm">3</button>
            <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-gray-600"><i class="fa-solid fa-chevron-right text-xs"></i></button>
        </div>
    </div>
</div>