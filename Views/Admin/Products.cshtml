@{
    Layout = null;
    ViewData["Title"] = "Admin - Product Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white shadow-md flex flex-col justify-between z-20">
        <div>
            <div class="px-6 py-8">
                <h1 class="text-2xl font-bold text-green-700">Admin</h1>
                <p class="text-xs text-gray-500">Management Console</p>
            </div>
            <nav class="mt-2">
                <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                    <i class="fa-solid fa-chart-line w-6 text-center"></i>
                    <span class="ml-3 font-medium">Dashboard</span>
                </a>
                <a href="#" class="flex items-center px-6 py-3 text-green-700 bg-gray-100 border-l-4 border-green-600">
                    <i class="fa-solid fa-box w-6 text-center"></i>
                    <span class="ml-3 font-medium">Products</span>
                </a>
                <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                    <i class="fa-solid fa-truck-fast w-6 text-center"></i>
                    <span class="ml-3 font-medium">Orders</span>
                </a>
                <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                    <i class="fa-solid fa-users w-6 text-center"></i>
                    <span class="ml-3 font-medium">Customers</span>
                </a>
                <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                    <i class="fa-solid fa-gear w-6 text-center"></i>
                    <span class="ml-3 font-medium">Settings</span>
                </a>
            </nav>
        </div>
        <div class="mb-8">
            <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                <i class="fa-regular fa-circle-question w-6 text-center"></i>
                <span class="ml-3 font-medium">Support</span>
            </a>
            <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50">
                <i class="fa-solid fa-arrow-right-from-bracket w-6 text-center"></i>
                <span class="ml-3 font-medium">Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col overflow-hidden bg-gray-50">
        
        <!-- Top Nav -->
        <header class="bg-white px-8 py-4 flex items-center justify-between border-b z-10">
            <nav class="hidden md:flex space-x-8 text-sm font-medium text-gray-600">
                <a href="#" class="hover:text-gray-900">Shop</a>
                <a href="#" class="hover:text-gray-900">Collections</a>
                <a href="#" class="hover:text-gray-900">Heritage</a>
                <a href="#" class="hover:text-gray-900">Journal</a>
            </nav>
            <div class="flex items-center space-x-6">
                <div class="relative">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                    <input type="text" placeholder="Search catalog..." class="bg-gray-100 text-sm rounded-full py-2 pl-9 pr-4 focus:outline-none focus:ring-1 focus:ring-green-500 w-48">
                </div>
                <button class="text-gray-500 hover:text-gray-700 relative">
                    <i class="fa-regular fa-bell text-lg"></i>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <button class="text-gray-500 hover:text-gray-700">
                    <i class="fa-regular fa-user text-lg"></i>
                </button>
            </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-y-auto p-8">
            
            <!-- Page Header -->
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Product Management</h2>
                    <p class="text-sm text-gray-500 mt-1">Curate and manage your fragrance collection</p>
                </div>
                <button class="bg-[#2ecc71] hover:bg-green-500 text-white font-medium py-2 px-4 rounded text-sm transition-colors flex items-center shadow-sm">
                    <i class="fa-solid fa-plus mr-2"></i> Add New Product
                </button>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                
                <!-- Total SKUs -->
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col justify-between">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Total SKUs</h3>
                    <div class="flex items-end space-x-3">
                        <span class="text-3xl font-bold text-gray-900">1,284</span>
                        <span class="text-sm font-medium text-green-500 flex items-center mb-1">
                            <i class="fa-solid fa-arrow-trend-up mr-1 text-xs"></i> 12
                        </span>
                    </div>
                </div>

                <!-- Out of Stock -->
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col justify-between">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Out of Stock</h3>
                    <div class="flex items-center space-x-3">
                        <span class="text-3xl font-bold text-gray-900">08</span>
                        <span class="text-xs font-bold text-red-500 uppercase flex items-center">
                            <i class="fa-solid fa-triangle-exclamation mr-1"></i> Action needed
                        </span>
                    </div>
                </div>

                <!-- Best Seller -->
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col justify-between">
                    <h3 class="text-xs font-bold text-green-500 uppercase tracking-wider mb-3">Best Seller</h3>
                    <div class="flex items-center">
                        <div class="w-12 h-12 bg-amber-800 rounded mr-4 flex-shrink-0"></div>
                        <div>
                            <p class="text-sm font-bold text-gray-900">Velvet Moss</p>
                            <p class="text-xs text-gray-500">425 units this month</p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Inventory List -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                    <h3 class="text-lg font-bold text-gray-900">Inventory List</h3>
                    <div class="flex space-x-4">
                        <button class="text-sm font-medium text-gray-600 hover:text-gray-900 flex items-center"><i class="fa-solid fa-filter mr-2 text-xs"></i> Filter</button>
                        <button class="text-sm font-medium text-gray-600 hover:text-gray-900 flex items-center"><i class="fa-solid fa-download mr-2 text-xs"></i> Export</button>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-gray-600">
                        <thead class="text-xs font-bold text-gray-400 uppercase bg-gray-50">
                            <tr>
                                <th class="px-6 py-4 w-2/5">Product</th>
                                <th class="px-6 py-4 w-1/5">Category</th>
                                <th class="px-6 py-4 w-1/5">Price</th>
                                <th class="px-6 py-4 w-1/5">Stock Status</th>
                                <th class="px-6 py-4 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <!-- Item 1 -->
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 bg-amber-100 rounded mr-4 flex-shrink-0 flex items-center justify-center">
                                            <i class="fa-solid fa-bottle-droplet text-amber-600"></i>
                                        </div>
                                        <div>
                                            <p class="font-bold text-gray-900">Midnight Cedar</p>
                                            <p class="text-xs text-gray-400 mt-0.5">SKU: MC-2024-001</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-medium text-green-700">WOODEN</td>
                                <td class="px-6 py-4 font-medium text-gray-900">$185.00</td>
                                <td class="px-6 py-4">
                                    <span class="flex items-center text-gray-600 font-medium text-sm">
                                        <span class="w-2 h-2 rounded-full bg-green-500 mr-2"></span>
                                        In Stock <span class="text-gray-400 ml-1">(42)</span>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center text-gray-400 hover:text-gray-700 cursor-pointer">
                                    <i class="fa-solid fa-ellipsis"></i>
                                </td>
                            </tr>
                            <!-- Item 2 -->
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 bg-red-100 rounded mr-4 flex-shrink-0 flex items-center justify-center">
                                            <i class="fa-solid fa-spray-can text-red-500"></i>
                                        </div>
                                        <div>
                                            <p class="font-bold text-gray-900">Petal & Mist</p>
                                            <p class="text-xs text-gray-400 mt-0.5">SKU: PM-2024-089</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-medium text-pink-500">FLORAL</td>
                                <td class="px-6 py-4 font-medium text-gray-900">$145.00</td>
                                <td class="px-6 py-4">
                                    <span class="flex items-center text-red-500 font-medium text-sm">
                                        <span class="w-2 h-2 rounded-full bg-red-500 mr-2"></span>
                                        Low Stock <span class="text-red-400 ml-1">(03)</span>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center text-gray-400 hover:text-gray-700 cursor-pointer">
                                    <i class="fa-solid fa-ellipsis"></i>
                                </td>
                            </tr>
                            <!-- Item 3 -->
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 bg-blue-100 rounded mr-4 flex-shrink-0 flex items-center justify-center">
                                            <i class="fa-solid fa-flask text-blue-500"></i>
                                        </div>
                                        <div>
                                            <p class="font-bold text-gray-900">Aegean Sea</p>
                                            <p class="text-xs text-gray-400 mt-0.5">SKU: AS-2024-112</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-medium text-blue-500">FRESH</td>
                                <td class="px-6 py-4 font-medium text-gray-900">$150.00</td>
                                <td class="px-6 py-4">
                                    <span class="flex items-center text-gray-600 font-medium text-sm">
                                        <span class="w-2 h-2 rounded-full bg-green-500 mr-2"></span>
                                        In Stock <span class="text-gray-400 ml-1">(128)</span>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center text-gray-400 hover:text-gray-700 cursor-pointer">
                                    <i class="fa-solid fa-ellipsis"></i>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between bg-gray-50">
                    <p class="text-sm text-gray-500">Showing 1-10 of 1,284 products</p>
                    <div class="flex items-center space-x-1">
                        <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-gray-600"><i class="fa-solid fa-chevron-left text-xs"></i></button>
                        <button class="w-8 h-8 flex items-center justify-center bg-green-600 text-white font-medium rounded text-sm">1</button>
                        <button class="w-8 h-8 flex items-center justify-center text-gray-600 hover:bg-gray-200 font-medium rounded text-sm">2</button>
                        <button class="w-8 h-8 flex items-center justify-center text-gray-600 hover:bg-gray-200 font-medium rounded text-sm">3</button>
                        <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-gray-600"><i class="fa-solid fa-chevron-right text-xs"></i></button>
                    </div>
                </div>
            </div>

        </div>
    </main>

</body>
</html>
